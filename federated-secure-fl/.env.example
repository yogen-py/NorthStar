# ──────────────────────────────────────────
# Project North Star — Environment Variables
# Copy to .env and customize as needed.
# ──────────────────────────────────────────

# Keycloak
KEYCLOAK_URL=http://keycloak:8080
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin


# Database
DB_URL=sqlite:///./trust.db

# Flower
SERVER_ADDRESS=fl-server:9080
FLOWER_NUM_ROUNDS=5

# Attack simulation (only used with --profile attack)
ATTACK_MODE=noise
