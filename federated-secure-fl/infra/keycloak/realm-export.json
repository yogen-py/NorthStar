{
    "realm": "fl-realm",
    "enabled": true,
    "displayName": "Federated Learning Realm",
    "sslRequired": "none",
    "registrationAllowed": false,
    "loginWithEmailAllowed": false,
    "duplicateEmailsAllowed": false,
    "resetPasswordAllowed": false,
    "editUsernameAllowed": false,
    "bruteForceProtected": true,
    "roles": {
        "realm": [
            {
                "name": "trainer",
                "description": "FL trainer role — allows participation in federated rounds"
            },
            {
                "name": "admin",
                "description": "FL admin role — manages trust scores and policies"
            }
        ]
    },
    "clients": [
        {
            "clientId": "fl-client",
            "enabled": true,
            "publicClient": false,
            "secret": "fl-client-secret",
            "directAccessGrantsEnabled": true,
            "serviceAccountsEnabled": true,
            "authorizationServicesEnabled": false,
            "protocol": "openid-connect"
        },
        {
            "clientId": "hospital_a",
            "enabled": true,
            "secret": "hospital_a_pass",
            "serviceAccountsEnabled": true,
            "protocol": "openid-connect",
            "protocolMappers": [
                {
                    "name": "client-id-mapper",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-hardcoded-claim-mapper",
                    "config": {
                        "claim.name": "clientId",
                        "claim.value": "hospital_a",
                        "jsonType.label": "String",
                        "access.token.claim": "true",
                        "id.token.claim": "true"
                    }
                }
            ]
        },
        {
            "clientId": "hospital_b",
            "enabled": true,
            "secret": "hospital_b_pass",
            "serviceAccountsEnabled": true,
            "protocol": "openid-connect",
            "protocolMappers": [
                {
                    "name": "client-id-mapper",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-hardcoded-claim-mapper",
                    "config": {
                        "claim.name": "clientId",
                        "claim.value": "hospital_b",
                        "jsonType.label": "String",
                        "access.token.claim": "true",
                        "id.token.claim": "true"
                    }
                }
            ]
        },
        {
            "clientId": "hospital_c",
            "enabled": true,
            "secret": "hospital_c_pass",
            "serviceAccountsEnabled": true,
            "protocol": "openid-connect",
            "protocolMappers": [
                {
                    "name": "client-id-mapper",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-hardcoded-claim-mapper",
                    "config": {
                        "claim.name": "clientId",
                        "claim.value": "hospital_c",
                        "jsonType.label": "String",
                        "access.token.claim": "true",
                        "id.token.claim": "true"
                    }
                }
            ]
        }
    ],
    "users": [
        {
            "username": "fl_admin",
            "enabled": true,
            "emailVerified": true,
            "credentials": [
                {
                    "type": "password",
                    "value": "admin_pass",
                    "temporary": false
                }
            ],
            "requiredActions": [],
            "realmRoles": [
                "admin"
            ]
        }
    ]
}